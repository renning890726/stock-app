# 数据库配置（PostgreSQL）
DATABASE_URL="postgresql://username:password@localhost:5432/stock_assistant"

# 应用配置
NODE_ENV="production"
PORT="5000"

# Python Akshare 服务配置
STOCK_SERVICE_URL="http://localhost:9001"

# LLM 配置（如果需要自定义）
LLM_MODEL="doubao-seed-1-8-251228"

# 日志配置
LOG_LEVEL="info"
LOG_DIR="/var/log/stock-assistant"

# 飞书 Webhook（可选，用于推送通知）
FEISHU_WEBHOOK_URL=""

# 时区配置
TZ="Asia/Shanghai"

# 缓存配置
CACHE_TTL_TRADING="30"      # 交易时间缓存有效期（秒）
CACHE_TTL_NON_TRADING="86400"  # 非交易时间缓存有效期（秒，24小时）

# 监控配置
MONITOR_ENABLED="true"
MONITOR_INTERVAL="60"       # 监控检查间隔（秒）

# 限流配置
RATE_LIMIT_ENABLED="true"
RATE_LIMIT_MAX_REQUESTS="100"
RATE_LIMIT_WINDOW="60"      # 限流时间窗口（秒）
